# Supabase — https://app.supabase.com → Project Settings → API
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_KEY=eyJ...            # clé "anon" (publique, côté client)
SUPABASE_SERVICE_KEY=eyJ...    # clé "service_role" (serveur uniquement : cron, scraping)

# Resend (V2 — emails d'alerte). Optionnel : sans clé, pas d'email envoyé.
RESEND_API_KEY=re_...
RESEND_FROM=Hovly <onboarding@resend.dev>

# Secret du cron de re-scraping. Header attendu : Authorization: Bearer <CRON_SECRET>
CRON_SECRET=change-me

# Anthropic (V3 — analyse IA)
ANTHROPIC_API_KEY=sk-ant-...
